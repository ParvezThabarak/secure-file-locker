{
  "name": "s3-file-manager-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Modern React frontend for S3 File Manager application",
  "keywords": ["react", "vite", "tailwind", "s3", "file-manager", "aws"],
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "docker:build": "docker build -t s3-file-manager-frontend .",
    "docker:run": "docker run -p 3000:80 s3-file-manager-frontend",
    "docker:dev": "docker-compose up --build",
    "docker:stop": "docker-compose down",
    "clean": "rm -rf dist node_modules/.vite",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "autoprefixer": "^10.4.21",
    "axios": "^1.12.2",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.9.4",
    "tailwindcss": "^3.4.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "vite": "^7.1.7"
  }
}
